# AI Car Concierge — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# ── LLM ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Used by ingest.py and retriever.py for ChromaDB embeddings
# Options: "openai" | "sentence-transformers"
# Use "sentence-transformers" to avoid needing an OpenAI key (slower first run, no cost)
EMBEDDING_PROVIDER=sentence-transformers
OPENAI_API_KEY=sk-...                      # Only required if EMBEDDING_PROVIDER=openai

# ── Email Automation ───────────────────────────────────────────────────────────
# Mailtrap SMTP sandbox — no domain verification required, free tier works
# Get credentials at https://mailtrap.io → Email Testing → SMTP Settings → Python
MAILTRAP_USERNAME=your_mailtrap_username
MAILTRAP_PASSWORD=your_mailtrap_password
EMAIL_FROM=concierge@premiumdealership.com  # Display-only, sandbox ignores domain

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=./data/inventory.db               # Path to SQLite database file

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma_db              # Path to ChromaDB persistence directory
CHROMA_COLLECTION=car_concierge_kb        # Collection name for knowledge base

# ── App Config ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development                   # "development" | "production"
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:8501        # Streamlit URL (for CORS)

# ── Railway / Deployment ───────────────────────────────────────────────────────
# PORT is set automatically by Railway. Do not override locally.
# PORT=8000
